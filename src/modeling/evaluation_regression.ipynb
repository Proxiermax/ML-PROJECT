    "    poly_regression_metrics[\"Sklearn Test MSE\"],\n",
    "    multiple_regression_metrics[\"Scratch Test MSE\"],\n",
    "    multiple_regression_metrics[\"Sklearn Test MSE\"],\n",
    "    mlp_regression_metrics[\"Test MSE\"],\n",
    "]\n",
    "\n",
    "x = np.arange(len(models))\n",
    "width = 0.35\n",
    "\n",
    "plt.figure(figsize=(14, 6))\n",
    "\n",
    "plt.bar(x - width/2, train_mse, width, label=\"Train MSE\")\n",
    "plt.bar(x + width/2, test_mse, width, label=\"Test MSE\")\n",
    "\n",
    "plt.xticks(x, models, rotation=30)\n",
    "plt.ylabel(\"MSE\")\n",
    "plt.title(\"Model Comparison (Train vs Test MSE)\")\n",
    "plt.legend()\n",
    "plt.grid(axis=\"y\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()"
